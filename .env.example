# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ai_receptionist?schema=public"

# Redis (optional for POC, but recommended)
REDIS_URL="redis://localhost:6379"

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+49XXXXXXXXXX
TWILIO_WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# AI Services
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Google Calendar (Phase 4)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
GOOGLE_CALENDAR_WEBHOOK_URL=

RESEND_API_KEY=
RESEND_FROM_EMAIL=
ENABLE_APPOINTMENT_REMINDERS=false

# JWT & Authentication
# Generate JWT_SECRET with: openssl rand -base64 48
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOGIN_RATE_LIMIT=5

# Rate Limiting Configuration
# Enable/disable rate limiting globally
RATE_LIMIT_ENABLED=true
# Use Redis for distributed rate limiting (recommended for production)
RATE_LIMIT_REDIS_ENABLED=true
# Max requests per minute for AI/Claude endpoints (cost control)
RATE_LIMIT_AI_MAX=10
# Max requests per minute for TTS generation (cost control)
RATE_LIMIT_TTS_MAX=20
# Max requests per minute for analytics queries (database protection)
RATE_LIMIT_ANALYTICS_MAX=10
# Max requests per minute for webhooks (soft limit, high threshold)
RATE_LIMIT_WEBHOOK_MAX=100

# HubSpot CRM (Phase 4)
HUBSPOT_API_KEY=

# Monitoring
SENTRY_DSN=

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173