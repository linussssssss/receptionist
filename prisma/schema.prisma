// Prisma schema for AI Receptionist POC

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Client/Customer configuration
model Client {
  id                String   @id @default(cuid())
  name              String
  industry          String   // dental, legal, medical, general
  phoneNumber       String   @unique
  email             String?
  
  // Business configuration
  businessHours     Json     // {monday: {start: "09:00", end: "17:00"}, ...}
  greetingMessage   String   @db.Text
  llmSystemPrompt   String   @db.Text
  voiceId           String?  // ElevenLabs voice ID
  useElevenLabsTTS  Boolean  @default(false) // Use ElevenLabs instead of Twilio Polly

  // Features and rules
  escalationRules   Json     // Transfer rules, keywords, etc.
  integrations      Json?    // Calendar, CRM configs
  isActive          Boolean  @default(true)
  
  // Metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  calls             Call[]
  appointments      Appointment[]
  calendarSyncs     CalendarSync[]
  calendarWebhook   CalendarWebhook?
  users             User[]
  invitations       Invitation[]

  @@index([phoneNumber])
  @@index([isActive])
}

// User accounts for dashboard access
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          UserRole  @default(STAFF)
  clientId      String

  // Account status
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)

  // Invitation tracking
  invitedBy     String?
  invitedAt     DateTime?

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Relations
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invitedUsers  User[]    @relation("UserInvitations")
  inviter       User?     @relation("UserInvitations", fields: [invitedBy], references: [id], onDelete: SetNull)
  sessions      Session[]
  invitations   Invitation[]

  @@index([email])
  @@index([clientId])
  @@index([isActive])
  @@index([role])
}

enum UserRole {
  ADMIN
  STAFF
}

// User sessions for JWT token revocation
model Session {
  id                String    @id @default(cuid())
  userId            String
  token             String    @unique  // JWT jti (unique identifier)
  refreshToken      String?   @unique

  // Session metadata
  ipAddress         String?
  userAgent         String?

  // Expiration
  expiresAt         DateTime
  refreshExpiresAt  DateTime?

  // Status
  isActive          Boolean   @default(true)
  revokedAt         DateTime?

  // Timestamps
  createdAt         DateTime  @default(now())
  lastUsedAt        DateTime  @default(now())

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([isActive])
}

// User invitations for invite-only registration
model Invitation {
  id           String           @id @default(cuid())
  email        String
  token        String           @unique
  role         UserRole         @default(STAFF)
  clientId     String
  invitedBy    String           // User ID

  // Status
  status       InvitationStatus @default(PENDING)

  // Expiration (7 days default)
  expiresAt    DateTime

  // Timestamps
  createdAt    DateTime         @default(now())
  acceptedAt   DateTime?

  // Relations
  client       Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inviter      User             @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
  @@index([clientId])
  @@index([status])
  @@index([expiresAt])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// Individual call record
model Call {
  id              String    @id @default(cuid())
  clientId        String
  
  // Call identification
  callSid         String    @unique  // Sipgate call ID
  callerNumber    String
  callerName      String?
  
  // Call status and timing
  status          CallStatus @default(RINGING)
  startTime       DateTime   @default(now())
  endTime         DateTime?
  duration        Int?       // seconds
  
  // Content
  recordingUrl    String?
  summary         String?    @db.Text
  
  // Conversation analysis
  intent          String?    // appointment, info, callback, emergency
  outcome         CallOutcome?
  sentiment       String?    // positive, neutral, negative
  
  // AI metadata
  tokensUsed      Int?
  cost            Float?     // Total cost in EUR
  latencyMs       Int?       // Average response latency
  
  // Additional data
  metadata        Json?
  
  // Relations
  client          Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messages        Message[]
  appointments    Appointment[]
  
  @@index([clientId])
  @@index([callSid])
  @@index([status])
  @@index([startTime])
  @@index([callerNumber])
}

enum CallStatus {
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
  CANCELLED
}

enum CallOutcome {
  APPOINTMENT_BOOKED
  INFORMATION_PROVIDED
  CALLBACK_REQUESTED
  TRANSFERRED_TO_HUMAN
  VOICEMAIL_LEFT
  HUNG_UP
  ERROR
}

// Individual messages in a conversation
model Message {
  id          String   @id @default(cuid())
  callId      String
  
  // Message content
  role        MessageRole
  content     String   @db.Text
  
  // Timing and performance
  timestamp   DateTime @default(now())
  latencyMs   Int?     // Response generation time
  
  // Audio data (for debugging/training)
  audioUrl    String?
  
  // AI metadata
  tokensUsed  Int?
  modelUsed   String?  // claude-sonnet-4.5, etc.
  
  // Relations
  call        Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  
  @@index([callId])
  @@index([timestamp])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// Appointment records
model Appointment {
  id              String            @id @default(cuid())
  callId          String?
  clientId        String
  
  // Customer information
  customerName    String
  customerPhone   String
  customerEmail   String?
  
  // Appointment details
  datetime        DateTime
  durationMinutes Int               @default(30)
  reason          String?           @db.Text
  notes           String?           @db.Text
  
  // Status tracking
  status          AppointmentStatus @default(PENDING)
  
  // External integration
  calendarId      String?           // Google Calendar event ID
  crmId           String?           // HubSpot contact/deal ID
  
  // Reminders
  reminderSent    Boolean           @default(false)
  reminderSentAt  DateTime?
  
  // Metadata
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relations
  call            Call?             @relation(fields: [callId], references: [id], onDelete: SetNull)
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  calendarSyncs   CalendarSync[]

  @@index([clientId])
  @@index([callId])
  @@index([datetime])
  @@index([status])
  @@index([customerPhone])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
}

// System events and audit log
model SystemEvent {
  id          String   @id @default(cuid())

  eventType   String   // call_started, call_ended, error, config_changed
  severity    String   // info, warning, error, critical

  message     String   @db.Text
  details     Json?

  // Context
  clientId    String?
  callId      String?
  userId      String?

  timestamp   DateTime @default(now())

  @@index([eventType])
  @@index([severity])
  @@index([timestamp])
  @@index([clientId])
}

// Calendar sync operations log
model CalendarSync {
  id              String                 @id @default(cuid())
  appointmentId   String
  clientId        String

  // Sync details
  operation       CalendarSyncOperation
  direction       CalendarSyncDirection
  status          CalendarSyncStatus     @default(PENDING)

  // Event data
  calendarEventId String?
  eventData       Json?                  // Snapshot of calendar event data

  // Error handling
  errorMessage    String?                @db.Text
  retryCount      Int                    @default(0)

  // Timestamps
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  syncedAt        DateTime?

  // Relations
  appointment     Appointment            @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client          Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

enum CalendarSyncOperation {
  CREATE
  UPDATE
  DELETE
}

enum CalendarSyncDirection {
  OUTBOUND  // AI Receptionist -> Calendar
  INBOUND   // Calendar -> AI Receptionist
}

enum CalendarSyncStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

// Google Calendar webhook channel subscriptions
model CalendarWebhook {
  id              String   @id @default(cuid())
  clientId        String   @unique

  // Google Channel details
  channelId       String   @unique  // Google's channel ID
  resourceId      String            // Google's resource ID
  expiration      DateTime          // When channel expires

  // Status
  isActive        Boolean  @default(true)

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([expiration])
}

// Alert log for monitoring and deduplication
model AlertLog {
  id          String   @id @default(cuid())

  alertType   String   // AlertType enum value (claude_api_failure, appointment_creation_failed, etc.)
  severity    String   // critical, warning, info
  alertHash   String   // Hash for deduplication (type + clientId + errorMessage)

  message     String   @db.Text
  details     Json?    // Additional context (stack trace, request details, etc.)

  // Context
  clientId    String?
  callId      String?
  userId      String?

  // Delivery tracking
  sentTo      String[] // Email addresses that received this alert
  sentAt      DateTime @default(now())

  @@index([alertType])
  @@index([alertHash])
  @@index([sentAt])
  @@index([clientId])
}

// Daily metrics for trend analysis and digest emails
model DailyMetrics {
  id          String   @id @default(cuid())
  date        DateTime @unique  // Date at midnight (start of day)

  // Aggregated metrics stored as JSON
  metrics     Json     // DailyDigestMetrics object

  createdAt   DateTime @default(now())

  @@index([date])
}